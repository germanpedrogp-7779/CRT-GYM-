//@version=6
strategy("CRT Bot - Candle Range Theory Strategy", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000, margin_long=100, margin_short=100)

// =====================================================================================
// DESCRIPCIÓN EN ESPAÑOL:
// Este script de TradingView en PineScript v6 implementa la metodología "Candle Range Theory" (CRT).
// CRT asume que cada vela representa un rango de precio. El bot opera la recolección de liquidez
// (barrido o sweep) de los extremos de un rango de referencia y busca un movimiento al extremo opuesto.
// Incluye gestión de riesgo profesional con tamaño de posición dinámico, stop loss dinámico/trailing,
// toma de ganancias parciales (hasta 3 niveles) y cierre automático de todas las operaciones los viernes
// a las 15:00 UTC-4 (GMT-4). Diseñado para interactuar con un backend en C# mediante alertas JSON.
//
// ENGLISH DESCRIPTION:
// This TradingView PineScript v6 strategy implements the "Candle Range Theory" (CRT) methodology.
// CRT posits that every candle represents a price range. The bot trades the liquidity sweeps (rejection)
// of reference range extremes and projects a move to the opposite extreme.
// It includes professional risk management with dynamic position sizing, dynamic/trailing stop loss,
// partial take profits (up to 3 levels), and automatic closing of all trades on Fridays at 15:00 UTC-4 (GMT-4).
// Fully webhook-ready with structured JSON payloads to trigger the C# backend execution engine.
// =====================================================================================

// ==========================================
// 1. INPUTS & CONFIGURACIÓN
// ==========================================

// Input Groups
gp_ref   = "CRT Reference Range Settings / Configuración de Rango CRT"
gp_entry = "Entry Confirmation Settings / Confirmación de Entradas"
gp_risk  = "Risk & Position Sizing Settings / Gestión de Riesgo y Tamaño de Posición"
gp_tp    = "Take Profit Settings (Partial Exits) / Ajustes de Take Profit Parcial"
gp_sl    = "Stop Loss Settings / Ajustes de Stop Loss"
gp_time  = "Trading Window & Friday Auto-Close / Ventana de Operación y Cierre de Viernes"

// --- Reference Range Settings ---
ref_source      = input.string("Previous Bar", "Reference Range Source / Origen del Rango", options=["Previous Bar", "HTF Bar", "Session Range"], group=gp_ref, tooltip="Select what defines the CRT range. 'Previous Bar' uses the prior candle. 'HTF Bar' maps a completed HTF candle (e.g., 4H) on the chart. 'Session Range' tracks a specific timezone-aware session (e.g., Asian Session).")
htf_tf          = input.timeframe("240", "HTF Timeframe (For HTF Bar)", group=gp_ref, tooltip="Timeframe of the reference candle when 'HTF Bar' is selected.")
session_time    = input.session("2000-0200", "Session Time (For Session Range)", group=gp_ref, tooltip="Time window for the reference range session (e.g., Asian Session 20:00 to 02:00 EST).")
session_tz      = input.string("GMT-4", "Session Timezone", options=["GMT-4", "GMT-5", "UTC", "America/New_York"], group=gp_ref, tooltip="Timezone for the Session Range calculation.")

// --- Entry Confirmation Settings ---
entry_type      = input.string("Close Rejection", "Entry Trigger Type / Tipo de Entrada", options=["Close Rejection", "Structure Break"], group=gp_entry, tooltip="Close Rejection: Enter immediately on the close of the sweeping bar (Rejection). Structure Break: Wait for a close above/below the sweeping bar's high/low (MSS/BOS confirmation).")
confirmation    = input.bool(true, "Require Bullish/Bearish Candle Confirmation", group=gp_entry, tooltip="If true, a long entry requires the sweeping candle to close green, and a short entry requires it to close red.")
max_sweep_hold  = input.int(5, "Max Bars to Hold Sweep Trigger", minval=1, group=gp_entry, tooltip="For 'Structure Break' entry, maximum number of bars to wait for the break before the setup is invalidated.")

// --- Risk & Position Sizing Settings ---
risk_pct        = input.float(1.0, "Risk % per Trade / % de Riesgo por Trade", minval=0.1, maxval=10.0, step=0.1, group=gp_risk, tooltip="Percentage of account equity to risk on each trade.")
allow_fractional= input.bool(true, "Allow Fractional Position Sizes", group=gp_risk, tooltip="If false, position size is rounded down to the nearest whole unit (contract/share).")

// --- Stop Loss Settings ---
sl_type         = input.string("Sweep Extreme", "Stop Loss Type / Tipo de Stop Loss", options=["Sweep Extreme", "ATR", "Fixed Ticks"], group=gp_sl, tooltip="Sweep Extreme: SL goes below/above the sweep candle or reference range extreme (whichever is more extreme). ATR: Average True Range based SL. Fixed Ticks: Constant tick/pip distance SL.")
atr_len         = input.int(14, "ATR Length / Periodo de ATR", minval=1, group=gp_sl, tooltip="Length of ATR for Stop Loss calculation.")
atr_mult        = input.float(1.5, "ATR SL Multiplier / Multiplicador ATR", group=gp_sl, tooltip="Multiplier applied to ATR for Stop Loss distance.")
fixed_sl        = input.int(100, "Fixed SL (Ticks/Pips)", group=gp_sl, tooltip="Constant distance for Fixed SL in ticks/pips.")
sl_buf          = input.float(1.0, "SL Buffer (Pips/Ticks)", group=gp_sl, tooltip="Additional buffer in ticks/pips added to the Sweep Extreme SL.")

// --- Take Profit Settings (Partial Exits) ---
tp1_r           = input.float(1.0, "TP1 Risk-to-Reward Ratio (R:R)", group=gp_tp, tooltip="Risk-to-reward ratio for the first take profit (e.g., 1.0 means 1:1).")
tp1_a           = input.float(50.0, "TP1 Position Allocation %", minval=0.0, maxval=100.0, group=gp_tp, tooltip="Percentage of total entry quantity to close at TP1.")
tp2_r           = input.float(2.0, "TP2 Risk-to-Reward Ratio (R:R)", group=gp_tp, tooltip="Risk-to-reward ratio for the second take profit.")
tp2_a           = input.float(30.0, "TP2 Position Allocation %", minval=0.0, maxval=100.0, group=gp_tp, tooltip="Percentage of total entry quantity to close at TP2.")
tp3_r           = input.float(3.0, "TP3 Risk-to-Reward Ratio (R:R)", group=gp_tp, tooltip="Risk-to-reward ratio for the third take profit.")
tp3_a           = input.float(20.0, "TP3 Position Allocation %", minval=0.0, maxval=100.0, group=gp_tp, tooltip="Percentage of total entry quantity to close at TP3.")

// --- Dynamic SL & Trailing settings ---
enable_be       = input.bool(true, "Move SL to Breakeven after TP1 / Mover SL a Breakeven tras TP1", group=gp_tp, tooltip="Move the Stop Loss of the remaining position to the entry price after TP1 is hit.")
enable_trail    = input.bool(false, "Enable Trailing Stop / Activar Trailing Stop", group=gp_tp, tooltip="Enable trailing stop loss based on ATR once a target R:R is reached.")
trail_act       = input.float(1.5, "Trailing Activation R:R", group=gp_tp, tooltip="Target R:R level that triggers the trailing stop mechanism.")
trail_dist      = input.float(1.5, "Trailing Distance (ATR)", group=gp_tp, tooltip="Distance from high/low to trail the stop loss, measured in ATR.")

// --- Friday Auto-Close Settings ---
friday_close    = input.bool(true, "Auto-Close Friday 15:00 UTC-4", group=gp_time, tooltip="Automatically close all active trades on Fridays at 15:00 GMT-4/UTC-4.")


// ==========================================
// 2. REFERENCE RANGE DETECTION (LÓGICA CRT)
// ==========================================

// Variables to store the reference high and low
var float ref_high = na
var float ref_low = na

// Method 1: Previous Bar
if ref_source == "Previous Bar"
    ref_high := high[1]
    ref_low  := low[1]

// Method 2: HTF Bar (Higher Timeframe)
else if ref_source == "HTF Bar"
    // Fetch completed HTF High and Low to avoid lookahead bias (gaps=on/off handles real-time updates safely)
    ref_high := request.security(syminfo.tickerid, htf_tf, high[1], barmerge.gaps_off, barmerge.lookahead_off)
    ref_low  := request.security(syminfo.tickerid, htf_tf, low[1], barmerge.gaps_off, barmerge.lookahead_off)

// Method 3: Session Range (e.g. Asian Session)
else if ref_source == "Session Range"
    // Check if current bar is inside the session time
    in_sess = not na(time(timeframe.period, session_time, session_tz))
    
    var float s_high = na
    var float s_low  = na
    var bool s_active = false
    
    if in_sess
        if not s_active
            s_high   := high
            s_low    := low
            s_active := true
        else
            s_high   := math.max(s_high, high)
            s_low    := math.min(s_low, low)
    else
        s_active := false
        
    // Once the session closes, lock the high/low as our active reference range
    if not in_sess and in_sess[1]
        ref_high := s_high
        ref_low  := s_low


// ==========================================
// 3. SWEEP & ENTRY SIGNAL GENERATION
// ==========================================

// Sweep Detection: Checking if price has grabbed liquidity outside the reference range and rejected
bool bullish_sweep = false
bool bearish_sweep = false

if not na(ref_high) and not na(ref_low)
    // Bullish Sweep (Turtle Soup): Low drops below reference low, but closes back above reference low
    bullish_sweep := low < ref_low and close > ref_low
    
    // Bearish Sweep: High breaks above reference high, but closes back below reference high
    bearish_sweep := high > ref_high and close < ref_high

// Require candle color confirmation if configured
if confirmation
    if bullish_sweep and close < open // Sweep candle must be green
        bullish_sweep := false
    if bearish_sweep and close > open // Sweep candle must be red
        bearish_sweep := false

// Setup Tracking for Structure Break (MSS/BOS Entry)
var bool sweep_active_long    = false
var bool sweep_active_short   = false
var float sweep_trigger_high  = na
var float sweep_trigger_low   = na
var int bars_since_long_sweep = 0
var int bars_since_shrt_sweep = 0

// Lock in the high/low of the sweep bar as trigger levels for conservative entry
if bullish_sweep
    sweep_active_long    := true
    sweep_trigger_high   := high
    sweep_active_short   := false
    bars_since_long_sweep := 0
if bearish_sweep
    sweep_active_short   := true
    sweep_trigger_low    := low
    sweep_active_long    := false
    bars_since_shrt_sweep := 0

// Increment bar counters and expire stale sweep setups
if sweep_active_long
    bars_since_long_sweep += 1
    if bars_since_long_sweep > max_sweep_hold
        sweep_active_long  := false
        sweep_trigger_high := na
if sweep_active_short
    bars_since_shrt_sweep += 1
    if bars_since_shrt_sweep > max_sweep_hold
        sweep_active_short := false
        sweep_trigger_low  := na

// Final Signal Conditions
bool long_signal  = false
bool short_signal = false

if entry_type == "Close Rejection"
    long_signal  := bullish_sweep
    short_signal := bearish_sweep
else if entry_type == "Structure Break"
    // Wait for a close crossing above the high of the sweeping candle (MSS)
    if sweep_active_long and close > sweep_trigger_high
        long_signal        := true
        sweep_active_long  := false
        sweep_trigger_high := na
    // Wait for a close crossing below the low of the sweeping candle (MSS)
    if sweep_active_short and close < sweep_trigger_low
        short_signal       := true
        sweep_active_short := false
        sweep_trigger_low  := na


// ==========================================
// 4. RISK & STOP LOSS CALCULATIONS
// ==========================================

// Average True Range (ATR)
atr_val = ta.atr(atr_len)

float calc_sl_long  = na
float calc_sl_short = na

if sl_type == "Sweep Extreme"
    // SL below the lowest point (sweep low or reference low) minus buffer
    calc_sl_long  := math.min(low, ref_low) - (sl_buf * syminfo.mintick)
    calc_sl_short := math.max(high, ref_high) + (sl_buf * syminfo.mintick)
else if sl_type == "ATR"
    calc_sl_long  := close - (atr_mult * atr_val)
    calc_sl_short := close + (atr_mult * atr_val)
else if sl_type == "Fixed Ticks"
    calc_sl_long  := close - (fixed_sl * syminfo.mintick)
    calc_sl_short := close + (fixed_sl * syminfo.mintick)

// Ensure Stop Loss is valid and positive
calc_sl_long  := math.max(calc_sl_long, 0.00001)


// ==========================================
// 5. TIME CONSTRAINTS & FRIDAY AUTO-CLOSE
// ==========================================

// Check days of week in GMT-4 (UTC-4)
is_friday = dayofweek(time, "GMT-4") == dayofweek.friday
is_sat    = dayofweek(time, "GMT-4") == dayofweek.saturday
is_sun    = dayofweek(time, "GMT-4") == dayofweek.sunday

// Check if current bar is after 15:00 (15:00-23:59) on Friday in GMT-4
is_friday_auto_close_time = is_friday and (hour(time, "GMT-4") > 15 or (hour(time, "GMT-4") == 15 and minute(time, "GMT-4") >= 0))

// Only allow opening positions outside of Friday afternoon and the weekend
bool is_trading_allowed = not is_friday_auto_close_time and not is_sat and not is_sun


// ==========================================
// 6. ORDER EXECUTION & POSITION TRACKING
// ==========================================

// Persistent State Variables for Active Trades
var float trade_entry_price = na
var float trade_sl_price    = na
var float trade_tp1_price   = na
var float trade_tp2_price   = na
var float trade_tp3_price   = na
var bool  trade_tp1_hit     = false

in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0

// Reset trade parameters when position becomes flat
if strategy.position_size == 0
    trade_entry_price := na
    trade_sl_price    := na
    trade_tp1_price   := na
    trade_tp2_price   := na
    trade_tp3_price   := na
    trade_tp1_hit     := false

// Trade Entry Execution
if is_trading_allowed and strategy.position_size == 0
    if long_signal
        trade_entry_price := close
        trade_sl_price    := calc_sl_long
        
        // Calculate Target Prices based on risk-reward multipliers
        risk_dist         := trade_entry_price - trade_sl_price
        trade_tp1_price   := trade_entry_price + (risk_dist * tp1_r)
        trade_tp2_price   := trade_entry_price + (risk_dist * tp2_r)
        trade_tp3_price   := trade_entry_price + (risk_dist * tp3_r)
        trade_tp1_hit     := false
        
        // Dynamic Sizing based on risk percentage of equity
        cash_risk         = strategy.equity * (risk_pct / 100.0)
        float pos_size    = na
        if risk_dist > 0
            pos_size := cash_risk / (risk_dist * syminfo.pointvalue)
        if not allow_fractional
            pos_size := math.floor(pos_size)
            
        // Place Strategy Entry
        strategy.entry("Long", strategy.long, qty=pos_size)
        
        // Trigger Webhook Payload
        alert_payload = str.format('{"ticker": "{0}", "action": "BUY", "price": {1,number,#.#####}, "sl": {2,number,#.#####}, "tp1": {3,number,#.#####}, "tp1_pct": {4}, "tp2": {5,number,#.#####}, "tp2_pct": {6}, "tp3": {7,number,#.#####}, "tp3_pct": {8}}', 
             syminfo.ticker, trade_entry_price, trade_sl_price, trade_tp1_price, tp1_a, trade_tp2_price, tp2_a, trade_tp3_price, tp3_a)
        alert(alert_payload, alert.freq_once_per_bar)
        
    else if short_signal
        trade_entry_price := close
        trade_sl_price    := calc_sl_short
        
        // Calculate Target Prices based on risk-reward multipliers
        risk_dist         := trade_sl_price - trade_entry_price
        trade_tp1_price   := trade_entry_price - (risk_dist * tp1_r)
        trade_tp2_price   := trade_entry_price - (risk_dist * tp2_r)
        trade_tp3_price   := trade_entry_price - (risk_dist * tp3_r)
        trade_tp1_hit     := false
        
        // Dynamic Sizing based on risk percentage of equity
        cash_risk         = strategy.equity * (risk_pct / 100.0)
        float pos_size    = na
        if risk_dist > 0
            pos_size := cash_risk / (risk_dist * syminfo.pointvalue)
        if not allow_fractional
            pos_size := math.floor(pos_size)
            
        // Place Strategy Entry
        strategy.entry("Short", strategy.short, qty=pos_size)
        
        // Trigger Webhook Payload
        alert_payload = str.format('{"ticker": "{0}", "action": "SELL", "price": {1,number,#.#####}, "sl": {2,number,#.#####}, "tp1": {3,number,#.#####}, "tp1_pct": {4}, "tp2": {5,number,#.#####}, "tp2_pct": {6}, "tp3": {7,number,#.#####}, "tp3_pct": {8}}', 
             syminfo.ticker, trade_entry_price, trade_sl_price, trade_tp1_price, tp1_a, trade_tp2_price, tp2_a, trade_tp3_price, tp3_a)
        alert(alert_payload, alert.freq_once_per_bar)


// ==========================================
// 7. ACTIVE TRADE MANAGEMENT & PARTIAL EXITS
// ==========================================

if strategy.position_size != 0
    // Track if TP1 has been touched during this trade
    if in_long and not trade_tp1_hit and high >= trade_tp1_price
        trade_tp1_hit := true
    if in_short and not trade_tp1_hit and low <= trade_tp1_price
        trade_tp1_hit := true
        
    // Dynamic Stop Loss Adjustments
    float current_sl_price = trade_sl_price
    
    // Move to Breakeven after TP1 is hit
    if trade_tp1_hit and enable_be
        current_sl_price := trade_entry_price
        
    // Trailing Stop Loss Mechanism
    if enable_trail
        // Trailing activates after hitting trailing target R:R
        bool trail_active = false
        if in_long and high >= trade_entry_price + (trade_entry_price - trade_sl_price) * trail_act
            trail_active := true
        if in_short and low <= trade_entry_price - (trade_sl_price - trade_entry_price) * trail_act
            trail_active := true
            
        if trail_active
            float trail_sl = na
            if in_long
                trail_sl := high - (trail_dist * atr_val)
                current_sl_price := math.max(current_sl_price, trail_sl)
            if in_short
                trail_sl := low + (trail_dist * atr_val)
                current_sl_price := math.min(current_sl_price, trail_sl)
                
    // Split total order quantity into configured partial take profits
    float total_qty = math.abs(strategy.position_size)
    
    // Normalize allocations to sum to 100%
    float sum_allocations = tp1_a + tp2_a + tp3_a
    float exit_qty1 = total_qty * (tp1_a / (sum_allocations > 0 ? sum_allocations : 100.0))
    float exit_qty2 = total_qty * (tp2_a / (sum_allocations > 0 ? sum_allocations : 100.0))
    float exit_qty3 = total_qty * (tp3_a / (sum_allocations > 0 ? sum_allocations : 100.0))
    
    // Place separate exit orders for each portion of the trade sharing the same dynamic SL
    if in_long
        strategy.exit("Exit TP1", from_entry="Long", qty=exit_qty1, limit=trade_tp1_price, stop=current_sl_price)
        strategy.exit("Exit TP2", from_entry="Long", qty=exit_qty2, limit=trade_tp2_price, stop=current_sl_price)
        strategy.exit("Exit TP3", from_entry="Long", qty=exit_qty3, limit=trade_tp3_price, stop=current_sl_price)
    if in_short
        strategy.exit("Exit TP1", from_entry="Short", qty=exit_qty1, limit=trade_tp1_price, stop=current_sl_price)
        strategy.exit("Exit TP2", from_entry="Short", qty=exit_qty2, limit=trade_tp2_price, stop=current_sl_price)
        strategy.exit("Exit TP3", from_entry="Short", qty=exit_qty3, limit=trade_tp3_price, stop=current_sl_price)

// Friday afternoon automatic market close
if friday_close and is_friday_auto_close_time and strategy.position_size != 0
    strategy.close_all("Friday Auto-Close")
    
    // Notify C# backend via JSON webhook payload
    alert('{"ticker": "' + syminfo.ticker + '", "action": "CLOSE_ALL", "reason": "Friday Auto-Close"}', alert.freq_once_per_bar)


// ==========================================
// 8. VISUALS, PLOTS & DASHBOARD
// ==========================================

// Draw Reference Levels
plot(ref_high, "CRT Reference High / Techo", color=color.new(color.red, 30), linewidth=1, style=plot.style_stepline)
plot(ref_low, "CRT Reference Low / Suelo", color=color.new(color.green, 30), linewidth=1, style=plot.style_stepline)

// Highlight sweeps and entries
plotshape(bullish_sweep, "Bullish Sweep / Barrido Alcista", shape.triangleup, location.belowbar, color.new(color.green, 20), size=size.small)
plotshape(bearish_sweep, "Bearish Sweep / Barrido Bajista", shape.triangledown, location.abovebar, color.new(color.red, 20), size=size.small)

plotshape(long_signal, "LONG Entry / Compra", shape.labelup, location.belowbar, color.new(color.green, 0), text="LONG / COMPRA", textcolor=color.white, size=size.small)
plotshape(short_signal, "SHORT Entry / Venta", shape.labeldown, location.abovebar, color.new(color.red, 0), text="SHORT / VENTA", textcolor=color.white, size=size.small)

// Background color during active session monitoring
bgcolor(ref_source == "Session Range" and in_session ? color.new(color.blue, 96) : na, title="Session Active Background")

// Draw Dynamic Levels for Active Trade
var line entry_ln = na
var line sl_ln    = na
var line tp1_ln   = na
var line tp2_ln   = na
var line tp3_ln   = na

if strategy.position_size != 0
    if na(entry_ln)
        entry_ln := line.new(bar_index - 1, trade_entry_price, bar_index + 10, trade_entry_price, color=color.blue, width=1, style=line.style_dashed)
        sl_ln    := line.new(bar_index - 1, trade_sl_price, bar_index + 10, trade_sl_price, color=color.red, width=1, style=line.style_dashed)
        tp1_ln   := line.new(bar_index - 1, trade_tp1_price, bar_index + 10, trade_tp1_price, color=color.green, width=1, style=line.style_dashed)
        tp2_ln   := line.new(bar_index - 1, trade_tp2_price, bar_index + 10, trade_tp2_price, color=color.green, width=1, style=line.style_dashed)
        tp3_ln   := line.new(bar_index - 1, trade_tp3_price, bar_index + 10, trade_tp3_price, color=color.green, width=1, style=line.style_dashed)
    else
        line.set_xy1(entry_ln, bar_index - 5, trade_entry_price)
        line.set_xy2(entry_ln, bar_index + 10, trade_entry_price)
        line.set_xy1(sl_ln, bar_index - 5, trade_sl_price)
        line.set_xy2(sl_ln, bar_index + 10, trade_sl_price)
        line.set_xy1(tp1_ln, bar_index - 5, trade_tp1_price)
        line.set_xy2(tp1_ln, bar_index + 10, trade_tp1_price)
        line.set_xy1(tp2_ln, bar_index - 5, trade_tp2_price)
        line.set_xy2(tp2_ln, bar_index + 10, trade_tp2_price)
        line.set_xy1(tp3_ln, bar_index - 5, trade_tp3_price)
        line.set_xy2(tp3_ln, bar_index + 10, trade_tp3_price)
else
    if not na(entry_ln)
        line.delete(entry_ln)
        line.delete(sl_ln)
        line.delete(tp1_ln)
        line.delete(tp2_ln)
        line.delete(tp3_ln)
        entry_ln := na
        sl_ln    := na
        tp1_ln   := na
        tp2_ln   := na
        tp3_ln   := na

// On-Screen Dashboard / Panel Informativo
var table info_pnl = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 30), border_color=color.gray, border_width=1)
if barstate.islast
    table.cell(info_pnl, 0, 0, "CRT Bot Dashboard", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(info_pnl, 1, 0, strategy.position_size != 0 ? "ACTIVE / ACTIVO" : "IDLE / ESPERA", text_color=color.white, bgcolor=strategy.position_size != 0 ? color.green : color.orange, text_size=size.small)
    table.cell(info_pnl, 0, 1, "Ref Source / Origen", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 1, ref_source, text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 2, "CRT Range High / Techo", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 2, str.tostring(ref_high, "#.#####"), text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 3, "CRT Range Low / Suelo", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 3, str.tostring(ref_low, "#.#####"), text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 4, "Active Position / Posición", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 4, str.tostring(strategy.position_size, "#.####"), text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 5, "Trade Type / Tipo", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 5, strategy.position_size > 0 ? "LONG / COMPRA" : (strategy.position_size < 0 ? "SHORT / VENTA" : "NONE"), text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 6, "TP1 Hit / Parcial 1 Logrado", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 6, trade_tp1_hit ? "YES / SÍ" : "NO", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 0, 7, "Risk per Trade / Riesgo", text_color=color.white, text_size=size.small)
    table.cell(info_pnl, 1, 7, str.tostring(risk_pct, "#.#") + "%", text_color=color.white, text_size=size.small)


// =====================================================================================
// 9. WEBHOOK INTEGRATION / ALERT CONDITIONS (PARA BACKEND C#)
// =====================================================================================

// Classic Alert Conditions for custom triggers on TradingView's platform
alertcondition(long_signal, title="CRT Long Entry Alert (BUY)", message="[CRT Bot Webhook] BUY Signal on ticker {{ticker}} at price {{close}}. SL: {{plot_0}}, TP1: {{plot_1}}")
alertcondition(short_signal, title="CRT Short Entry Alert (SELL)", message="[CRT Bot Webhook] SELL Signal on ticker {{ticker}} at price {{close}}. SL: {{plot_2}}, TP1: {{plot_1}}")

// Exits & Event triggers
bool hit_tp1_long  = in_long and not trade_tp1_hit and high >= trade_tp1_price
bool hit_tp1_short = in_short and not trade_tp1_hit and low <= trade_tp1_price
alertcondition(hit_tp1_long or hit_tp1_short, title="CRT Partial Take Profit (TP1) Hit Alert", message="[CRT Bot Webhook] Partial exit target TP1 hit on ticker {{ticker}}.")

bool hit_sl_long   = in_long and low <= trade_sl_price
bool hit_sl_short  = in_short and high >= trade_sl_price
alertcondition(hit_sl_long or hit_sl_short, title="CRT Stop Loss (SL) Hit Alert", message="[CRT Bot Webhook] Stop Loss hit on ticker {{ticker}}.")

alertcondition(is_friday_auto_close_time and strategy.position_size != 0, title="CRT Friday Auto-Close Trigger Alert", message="[CRT Bot Webhook] Friday afternoon market auto-close executed on {{ticker}}.")
